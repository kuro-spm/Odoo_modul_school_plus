<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="action_qweb_student_report" model="ir.actions.report">
        <field name="name">Student Report</field>
        <field name="model">schoolplus.student</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">schoolplus.report_student_template</field>
        <field name="report_file">schoolplus.report_student_template</field>
        <field name="model_id" ref="schoolplus.model_schoolplus_student" />
        <field name="binding_model_id" ref="schoolplus.model_schoolplus_student" />
        <field name="binding_type">report</field>
    </record>

    <template id="report_student_template">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="o">
                <t t-call="web.external_layout">
                    <div class="page">
                        <!--Inici del report-->
                        <div class="text-end">
                            <span t-esc="datetime.datetime.now()" t-options="{'widget': 'datetime'}"></span>
                        </div>

                        <div class="text-center">
                            <h1>Student</h1>
                        </div>


                        <!--Final del report-->
                    </div>
                </t>
            </t>
        </t>
    </template>


</odoo>