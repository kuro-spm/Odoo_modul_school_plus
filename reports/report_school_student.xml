<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="action_qweb_student_report" model="ir.actions.report">
        <field name="name">Student Report</field>
        <field name="model">school.student</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">school.report_student_template</field>
        <field name="report_file">school.report_student_template</field>
        <field name="model_id" ref="school.model_school_student" />
        <field name="binding_model_id" ref="school.model_school_student" />
        <field name="binding_type">report</field>
    </record>

    <template id="report_student_template">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="o">
                <t t-call="web.external_layout">
                    <div class="page">
                        <!--Inici del report-->
                        <div class="text-end">
                            <span t-esc="datetime.datetime.now()" t-options="{'widget': 'datetime'}"></span>
                        </div>
                        <div class="text-center">
                            <h1>Student</h1>
                        </div>
                        <table class="table table-condensed table-borderless">
                            <tbody>
                                <tr>
                                    <td>
                                        <strong>Name:</strong>
                                    </td>
                                    <td colspan="3">
                                        <span t-field="o.display_name"></span>
                                    </td>
                                    <td>
                                        <strong>Birthdate:</strong>
                                    </td>
                                    <td colspan="3">
                                        <span t-field="o.birthdate"></span>
                                    </td>
                                </tr>
                                <tr>
                                    <td>
                                        <strong>Country:</strong>
                                    </td>
                                    <td colspan="3">
                                        <span t-field="o.country_id.name"></span>
                                    </td>
                                    <td>
                                        <strong>Gender:</strong>
                                    </td>
                                    <td colspan="3">
                                        <span t-field="o.gender"></span>
                                    </td>
                                </tr>
                                <tr>
                                    <td>
                                        <strong>Phone:</strong>
                                    </td>
                                    <td colspan="3">
                                        <span t-field="o.phone"></span>
                                    </td>
                                    <td>
                                        <strong>Email:</strong>
                                    </td>
                                    <td colspan="3">
                                        <span t-field="o.email"></span>
                                    </td>
                                </tr>
                                <tr>
                                    <td colspan="4">
                                        <strong>Address:</strong>
                                        <span t-field="o.address1"></span>
                                        <span t-field="o.address2"></span>
                                        <span t-field="o.zip_code"></span>
                                        <span t-field="o.city"></span>
                                        <span t-field="o.state_id.name"></span>
                                        <span t-field="o.state_country_id.name"></span>
                                    </td>
                                </tr>

                                <t t-if="o.age &gt; 14">
                                    <tr>
                                        <td>
                                            <strong>TIN:</strong>
                                        </td>
                                        <td colspan="3">
                                            <span t-field="o.tin"></span>
                                        </td>
                                    </tr>
                                </t>
                                <t t-if="o.age &lt; 18">
                                    <tr>
                                        <td>
                                            <strong>Guardian's Information:</strong>
                                        </td>
                                        <td colspan="3">
                                            <span t-field="o.guardian_info"></span>
                                        </td>
                                    </tr>
                                </t>

                            </tbody>

                        </table>


                        <!--Final del report-->
                    </div>
                </t>
            </t>
        </t>
    </template>


</odoo>