    <!--Els parent que fan referencia a un altre mòdul, necessiten el prefix del nom del mòdul!-->
    <menuitem
        id="school_enrollment_menu"
        name="Enrollment"
        sequence="20"
        parent='school.menu_root'
        action='school_enrollment_action' />

