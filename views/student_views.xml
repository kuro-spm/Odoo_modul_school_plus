<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- model.name form view -->
    <record id="school_student_view_list" model="ir.ui.view">
        <field name="name">school.student.view.list</field>
        <field name="model">school.student</field>
        <field name="arch" type="xml">
            <list string="Students">
                <field name="display_name" string="Full name"></field>
                <field name="age"></field>
                <field name="phone"></field>
                <field name="email"></field>
            </list>
        </field>
    </record>

    <!-- school.student form view -->
    <record id="school_student_view_form" model="ir.ui.view">
        <field name="name">school.student.view.form</field>
        <field name="model">school.student</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <field name="age" invisible="1" /> <!-- Cal que 'age' estigui a la vista per poder-lo avaluar -->
                    <group>
                        <group>
                            <field name="first_name" />
                            <field name="last_name" />

                            <!-- Grup intern de 4 columnes per posar 2 camps a la mateixa fila -->
                            <group col="4" colspan="2"> <!--class="mt-0 mb-0"-->
                                <field name="birthdate" widget="calendar" />
                                <field name="country_id" string="Birthcountry" />
                                <field name="gender" />
                                <field name="tin" required="age &gt;= 14" />
                            </group>

                            <field name="phone" widget="phone" />
                            <field name="email" />

                            <field name="address1" />
                            <field name="address2" />
                            <field name="zip_code" />
                            <field name="city" />
                            <field name="state_id" />
                        </group>
                    </group>
                    <group col='4' string="Guardian's information">
                        <!-- A l'XML, dins del <form> -->
                        <field name="guardian_info" required="age &lt; 18" />
                        <group string="Paying tutor information">
                            <field name="customer_id" />
                            <!--Necessitem els camps del customer_id dins del model-->      
                            <field name="customer_phone" />
                            <field name="customer_street" />
                            <field name="customer_street2" />
                            <field name="customer_zip" />
                            <field name="customer_city" />
                            <field name="customer_state_id" />
                            <field name="customer_country_id" />
                        </group>

                    </group>
                    <notebook>
                        <page string="Enrollments">
                            <field name="enrollment_ids">
                                <list>
                                    <field name="edition_id" string="Course Edition" />
                                    <field name="qualification" />
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>


</odoo>