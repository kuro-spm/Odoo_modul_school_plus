<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- res.partner form view -->
    <record id="res_partner_view_form" model="ir.ui.view">
        <field name="name">res.partner.view.form</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref='base.view_partner_form' />
        <field name="arch" type="xml">
            <!-- Localitzem el notebook i afegim la pestanya al final[cite: 1, 3] -->
            <xpath expr="//notebook" position="inside">
                <page name="students" string="Students" invisible="customer_rank == 0"> 
                    <field name="student_ids" readonly='1'>
                        <list>
                            <field name="display_name" string="Full name"></field>
                        </list>
                    </field>
                </page>
            </xpath>
        </field>
    </record>

</odoo>