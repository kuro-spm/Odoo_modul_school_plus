<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- res.partner form view -->
    <!--TODO: Averiguar per què no apareix la nova page a la vista.-->
    <!--Vigilem amb els noms per no xafar res: afegim inherit-->
    <record id="res_partner_view_form_inherit" model="ir.ui.view">
        <field name="name">res.partner.view.form.inherit</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref='base.view_partner_form' />
        <field name="arch" type="xml">
            <!-- Localitzem el notebook i afegim la pestanya-->
            <xpath expr="//notebook" position="inside">
                <page name="students" string="Students"> <!--invisible="customer_rank == 0"-->
                    <field name="student_ids" readonly='1'>
                        <list>
                            <field name="display_name" string="Full name"></field>
                        </list>
                    </field>
                </page>
            </xpath>
        </field>
    </record>

</odoo>